# Groq API Key for Free Tier
# Get your API key from: https://console.groq.com/keys
# This key is used server-side in the Netlify function to provide free tier access
# Copy this file to .env and add your actual API key
#
# Groq's free tier is very generous:
# - 30 requests/minute
# - 14,400 requests/day
# - No credit card required
GROQ_FREE_TIER_KEY=gsk_your-key-here
